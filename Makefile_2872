CC      = gcc
CFLAGS  = -Wall -Wextra -g
LIBS    = -lssl -lcrypto
TARGET  = server_2872
SRC     = server_2872.c

all: $(TARGET)
	@echo "✓ Build successful → ./$(TARGET)"

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) -o $(TARGET) $(SRC) $(LIBS)

clean:
	rm -f $(TARGET)
	@echo "Cleaned."

run: all
	./$(TARGET)
